rules_version = '2';

// Paste these into Firebase console → Firestore Database → Rules → Publish.
//
// The single content document (quiz/content) holds all the broadcast questions.
// It is world-READABLE so every display (any device) can load the questions, and
// WRITABLE only by a client that sends the correct editKey — i.e. the host who
// typed the edit password ("198999"). This is "basic" protection: the key ships
// in the client bundle, so it blocks casual writes, not a determined attacker.
// For stronger security, enable Anonymous Auth and gate writes on request.auth.
service cloud.firestore {
  match /databases/{database}/documents {

    match /quiz/content {
      allow read: if true;
      allow write: if request.resource.data.editKey == "198999";
    }

    // everything else stays locked
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
